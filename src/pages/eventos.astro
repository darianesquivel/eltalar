---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/eventos/Hero.astro";
import { Image } from "astro:assets";
import { CalendarDays, Clock, MapPin } from "@lucide/astro";
import { getUpcomingEvents } from "../lib/repositories/event.repository";

const events = await getUpcomingEvents(Astro.locals.barrio.id);

const MESES = [
  "ENE",
  "FEB",
  "MAR",
  "ABR",
  "MAY",
  "JUN",
  "JUL",
  "AGO",
  "SEP",
  "OCT",
  "NOV",
  "DIC",
];
const DIAS = [
  "domingo",
  "lunes",
  "martes",
  "miércoles",
  "jueves",
  "viernes",
  "sábado",
];

// "2026-07-18" → partes para el badge de fecha (sin tocar timezones:
// parsear el string evita el corrimiento de un día de new Date("YYYY-MM-DD"))
function dateParts(iso: string) {
  const [y, m, d] = iso.split("-").map(Number);
  const weekday = DIAS[new Date(y, m - 1, d).getDay()];
  return { day: d, month: MESES[m - 1], weekday };
}

const hora = (t: string | null) => (t ? t.slice(0, 5) : null);

function rangoFechas(e: (typeof events)[number]) {
  const from = dateParts(e.date);
  if (!e.end_date || e.end_date === e.date) return null;
  const to = dateParts(e.end_date);
  return `Del ${from.day} ${from.month} al ${to.day} ${to.month}`;
}
---

<Layout
  title={`Eventos en ${Astro.locals.barrio.name}`}
  description={`Agenda de eventos de ${Astro.locals.barrio.name}: ferias, festivales, actividades del barrio con día, horario y lugar.`}
>
  <Hero />

  <section id="eventos" class="mx-auto max-w-5xl space-y-8 px-4">
    {
      events.length === 0 ? (
        <div class="rounded-3xl bg-white px-6 py-16 text-center shadow-sm">
          <CalendarDays size={40} class="mx-auto text-gray-300" />
          <p class="mt-4 font-semibold text-gray-700">
            No hay eventos anunciados por ahora
          </p>
          <p class="mt-1 text-sm text-gray-500">
            Volvé a mirar en unos días — acá va a estar la agenda del barrio.
          </p>
        </div>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2">
          {events.map((e) => {
            const { day, month, weekday } = dateParts(e.date);
            const inicio = hora(e.start_time);
            const fin = hora(e.end_time);
            const rango = rangoFechas(e);
            return (
              <article class="flex flex-col overflow-hidden rounded-2xl bg-white shadow-lg">
                <div class="relative">
                  {e.image_url ? (
                    <Image
                      src={e.image_url}
                      alt={e.title}
                      width={640}
                      height={320}
                      widths={[480, 640]}
                      sizes="(max-width: 640px) 100vw, 50vw"
                      class="h-48 w-full object-cover"
                    />
                  ) : (
                    <div
                      class="flex h-48 w-full items-center justify-center"
                      style="background: linear-gradient(135deg, #ede9fe, #ddd6fe)"
                    >
                      <CalendarDays size={44} class="text-violet-400" />
                    </div>
                  )}

                  {/* Badge de fecha */}
                  <div class="absolute left-4 top-4 rounded-xl bg-white/95 px-3.5 py-2 text-center shadow">
                    <p class="text-xl font-bold leading-none text-gray-900">
                      {day}
                    </p>
                    <p class="text-[11px] font-bold tracking-wide text-violet-600">
                      {month}
                    </p>
                  </div>
                </div>

                <div class="flex flex-1 flex-col gap-2.5 p-6">
                  <h2 class="text-lg font-bold text-gray-900">{e.title}</h2>

                  <p class="flex items-center gap-2 text-sm capitalize text-gray-600">
                    <CalendarDays size={16} class="shrink-0 text-violet-500" />
                    {rango ??
                      `${weekday} ${day} de ${MESES[Number(e.date.split("-")[1]) - 1].toLowerCase()}.`}
                  </p>

                  {inicio && (
                    <p class="flex items-center gap-2 text-sm text-gray-600">
                      <Clock size={16} class="shrink-0 text-violet-500" />
                      {fin ? `${inicio} a ${fin} hs` : `${inicio} hs`}
                    </p>
                  )}

                  {e.location && (
                    <p class="flex items-center gap-2 text-sm text-gray-600">
                      <MapPin size={16} class="shrink-0 text-violet-500" />
                      {e.location}
                    </p>
                  )}

                  {e.description && (
                    <p class="mt-1 text-sm leading-relaxed text-gray-600">
                      {e.description}
                    </p>
                  )}
                </div>
              </article>
            );
          })}
        </div>
      )
    }
  </section>
</Layout>
