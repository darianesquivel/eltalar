---
import Layout from "../layouts/Layout.astro";
import { supabase } from "../lib/supabase";
// El CSS de Leaflet va en el frontmatter: así queda como <link> de la página
// y el ClientRouter lo espera ANTES del swap. Dentro del script podía llegar
// después de que Leaflet midiera el layout → mapa roto hasta recargar.
import "leaflet/dist/leaflet.css";

const { barrio } = Astro.locals;

// Negocios activos con coordenadas, con sus categorías (todas: sirven para
// el filtro; la primera se muestra en el popup).
// En páginas de a 1000: Supabase corta cualquier consulta en 1000 filas,
// y ya hay ~1700 negocios — una sola consulta dejaba medio mapa vacío.
const PAGE = 1000;
const rows: any[] = [];
for (let from = 0; ; from += PAGE) {
  const { data } = await supabase
    .from("businesses")
    .select(
      "id, name, slug, address, lat, lng, is_featured, business_categories ( categories ( name, slug ) )",
    )
    .eq("barrio_id", barrio.id)
    .eq("is_active", true)
    .not("lat", "is", null)
    .not("lng", "is", null)
    .order("id")
    .range(from, from + PAGE - 1);

  rows.push(...(data ?? []));
  if (!data || data.length < PAGE) break;
}

const markers = rows.map((b) => ({
  name: b.name,
  slug: b.slug,
  address: b.address,
  // 5 decimales ≈ 1 m: suficiente para el mapa y achica el HTML
  lat: Math.round(b.lat * 1e5) / 1e5,
  lng: Math.round(b.lng * 1e5) / 1e5,
  featured: b.is_featured === true,
  category: b.business_categories?.[0]?.categories?.name ?? null,
  cats: (b.business_categories ?? [])
    .map((bc: any) => bc.categories?.slug)
    .filter(Boolean),
}));

const { data: categories } = await supabase
  .from("categories")
  .select("name, slug")
  .eq("is_active", true)
  .order("name");
---

<Layout
  title={`Mapa de negocios de ${barrio.name}`}
  description={`Todos los negocios y servicios de ${barrio.name} en un mapa: encontrá el más cercano y entrá a su ficha con horarios y contacto.`}
>
  <section class="space-y-6">
    <div class="text-center space-y-2">
      <h1 class="text-3xl font-bold">Mapa del barrio</h1>
      <p class="text-gray-600">
        <span id="map-count">{markers.length}</span> negocios en el mapa · tocá un
        punto para ver la ficha
      </p>
    </div>

    <!-- Filtros: mismos controles que /negocios, filtran los puntos en vivo -->
    <div class="mx-auto flex w-full max-w-2xl flex-col gap-3 sm:flex-row">
      <input
        type="text"
        id="map-search"
        placeholder="Buscar comercio..."
        class="field flex-1"
      />
      <select id="map-category" class="field select-field sm:w-64">
        <option value="">Todas las categorías</option>
        {
          (categories ?? []).map((c) => (
            <option value={c.slug}>{c.name}</option>
          ))
        }
      </select>
    </div>

    <div
      id="map"
      class="h-[70vh] w-full rounded-3xl shadow-sm z-0"
      data-markers={JSON.stringify(markers)}
      data-center={JSON.stringify([barrio.lat, barrio.lng])}
    >
    </div>
  </section>
</Layout>

<script>
  import L from "leaflet";

  type MarkerData = {
    name: string;
    slug: string;
    address: string | null;
    lat: number;
    lng: number;
    featured: boolean;
    category: string | null;
    cats: string[];
  };

  const normalize = (s: string) =>
    s
      .toLowerCase()
      .normalize("NFD")
      .replace(/[\u0300-\u036f]/g, "");

  const setupMap = () => {
    const el = document.getElementById("map");
    if (!el || el.dataset.initialized) return;
    el.dataset.initialized = "true";

    const markers: MarkerData[] = JSON.parse(el.dataset.markers ?? "[]");
    const center: [number, number] = JSON.parse(
      el.dataset.center ?? "[-34.4716, -58.655]",
    );

    // Centro del barrio (viene del server). preferCanvas: con ~1700
    // marcadores, dibujarlos en canvas es fluido; como SVG se arrastra.
    const map = L.map(el, { preferCanvas: true }).setView(center, 14);

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 19,
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    }).addTo(map);

    const allBounds: L.LatLngTuple[] = [];

    // Un circleMarker por negocio; el filtro los agrega/saca del mapa
    const entries = markers.map((m) => {
      const marker = L.circleMarker([m.lat, m.lng], {
        radius: m.featured ? 10 : 7,
        color: "#ffffff",
        weight: 2,
        fillColor: m.featured ? "#f59e0b" : "#16a34a",
        fillOpacity: 0.95,
      }).addTo(map);

      marker.bindPopup(
        `<div style="min-width:180px">
          <strong>${m.name}</strong>${m.featured ? " ⭐" : ""}<br/>
          ${m.category ? `<span style="color:#16a34a;font-size:12px">${m.category}</span><br/>` : ""}
          ${m.address ? `<span style="color:#666;font-size:12px">${m.address}</span><br/>` : ""}
          <a href="/negocios/${m.slug}" style="color:#16a34a;font-weight:600">Ver ficha →</a>
        </div>`,
      );

      allBounds.push([m.lat, m.lng]);
      // texto pre-normalizado: buscar mientras se tipea no recalcula 1700 veces
      const haystack = normalize(`${m.name} ${m.address ?? ""}`);
      return { marker, m, haystack };
    });

    if (allBounds.length > 0) {
      map.fitBounds(allBounds, { padding: [40, 40], maxZoom: 15 });
    }

    // ---------- Filtros ----------
    const searchInput = document.getElementById(
      "map-search",
    ) as HTMLInputElement | null;
    const categorySelect = document.getElementById(
      "map-category",
    ) as HTMLSelectElement | null;
    const countEl = document.getElementById("map-count");

    const applyFilters = (refit: boolean) => {
      const q = normalize(searchInput?.value.trim() ?? "");
      const cat = categorySelect?.value ?? "";

      const visibleBounds: L.LatLngTuple[] = [];
      let visible = 0;

      for (const { marker, m, haystack } of entries) {
        const show =
          (!cat || m.cats.includes(cat)) && (!q || haystack.includes(q));

        if (show) {
          if (!map.hasLayer(marker)) marker.addTo(map);
          visibleBounds.push([m.lat, m.lng]);
          visible++;
        } else if (map.hasLayer(marker)) {
          map.removeLayer(marker);
        }
      }

      if (countEl) countEl.textContent = String(visible);

      // Al elegir categoría, encuadrar los puntos que quedaron
      if (refit && visibleBounds.length > 0) {
        map.fitBounds(visibleBounds, { padding: [40, 40], maxZoom: 16 });
      }
    };

    let debounce: ReturnType<typeof setTimeout>;
    searchInput?.addEventListener("input", () => {
      clearTimeout(debounce);
      debounce = setTimeout(() => applyFilters(false), 300);
    });
    categorySelect?.addEventListener("change", () => applyFilters(true));

    // Blindaje contra la carrera con las view transitions: si Leaflet midió
    // el contenedor durante la animación del swap, el tamaño queda mal y se
    // ven tiles grises/cortadas. Recalcular un par de veces lo corrige.
    const refit = () => {
      map.invalidateSize();
      if (allBounds.length > 0) {
        map.fitBounds(allBounds, { padding: [40, 40], maxZoom: 15 });
      }
    };
    setTimeout(refit, 250);
    setTimeout(refit, 800);
  };

  const initWhenReady = () => {
    // Esperar un frame: garantiza que el DOM nuevo ya está pintado
    requestAnimationFrame(() => setTimeout(setupMap, 0));
  };

  initWhenReady();
  document.addEventListener("astro:page-load", initWhenReady);
</script>
