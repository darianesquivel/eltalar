---
import Layout from "../layouts/Layout.astro";
import { supabase } from "../lib/supabase";
// El CSS de Leaflet va en el frontmatter: así queda como <link> de la página
// y el ClientRouter lo espera ANTES del swap. Dentro del script podía llegar
// después de que Leaflet midiera el layout → mapa roto hasta recargar.
import "leaflet/dist/leaflet.css";

// Negocios activos con coordenadas, con su categoría principal.
// En páginas de a 1000: Supabase corta cualquier consulta en 1000 filas,
// y ya hay ~1700 negocios — una sola consulta dejaba medio mapa vacío.
const PAGE = 1000;
const rows: any[] = [];
for (let from = 0; ; from += PAGE) {
  const { data } = await supabase
    .from("businesses")
    .select(
      "id, name, slug, address, lat, lng, is_featured, business_categories ( categories ( name ) )",
    )
    .eq("is_active", true)
    .not("lat", "is", null)
    .not("lng", "is", null)
    .order("id")
    .range(from, from + PAGE - 1);

  rows.push(...(data ?? []));
  if (!data || data.length < PAGE) break;
}

const markers = rows.map((b) => ({
  name: b.name,
  slug: b.slug,
  address: b.address,
  // 5 decimales ≈ 1 m: suficiente para el mapa y achica el HTML
  lat: Math.round(b.lat * 1e5) / 1e5,
  lng: Math.round(b.lng * 1e5) / 1e5,
  featured: b.is_featured === true,
  category: b.business_categories?.[0]?.categories?.name ?? null,
}));
---

<Layout
  title="Mapa de negocios de El Talar"
  description="Todos los negocios y servicios de El Talar en un mapa: encontrá el más cercano y entrá a su ficha con horarios y contacto."
>
  <section class="space-y-6">
    <div class="text-center space-y-2">
      <h1 class="text-3xl font-bold">Mapa del barrio</h1>
      <p class="text-gray-600">
        {markers.length} negocios en el mapa · tocá un punto para ver la ficha
      </p>
    </div>

    <div
      id="map"
      class="h-[70vh] w-full rounded-3xl shadow-sm z-0"
      data-markers={JSON.stringify(markers)}
    >
    </div>
  </section>
</Layout>

<script>
  import L from "leaflet";

  type MarkerData = {
    name: string;
    slug: string;
    address: string | null;
    lat: number;
    lng: number;
    featured: boolean;
    category: string | null;
  };

  const setupMap = () => {
    const el = document.getElementById("map");
    if (!el || el.dataset.initialized) return;
    el.dataset.initialized = "true";

    const markers: MarkerData[] = JSON.parse(el.dataset.markers ?? "[]");

    // Centro aproximado de El Talar. preferCanvas: con ~1700 marcadores,
    // dibujarlos en canvas es fluido; como SVG el mapa se arrastra.
    const map = L.map(el, { preferCanvas: true }).setView(
      [-34.4716, -58.655],
      14,
    );

    L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
      maxZoom: 19,
      attribution:
        '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
    }).addTo(map);

    const bounds: L.LatLngTuple[] = [];

    markers.forEach((m) => {
      // circleMarker: no depende de assets de íconos
      const marker = L.circleMarker([m.lat, m.lng], {
        radius: m.featured ? 10 : 7,
        color: "#ffffff",
        weight: 2,
        fillColor: m.featured ? "#f59e0b" : "#16a34a",
        fillOpacity: 0.95,
      }).addTo(map);

      marker.bindPopup(
        `<div style="min-width:180px">
          <strong>${m.name}</strong>${m.featured ? " ⭐" : ""}<br/>
          ${m.category ? `<span style="color:#16a34a;font-size:12px">${m.category}</span><br/>` : ""}
          ${m.address ? `<span style="color:#666;font-size:12px">${m.address}</span><br/>` : ""}
          <a href="/negocios/${m.slug}" style="color:#16a34a;font-weight:600">Ver ficha →</a>
        </div>`,
      );

      bounds.push([m.lat, m.lng]);
    });

    if (bounds.length > 0) {
      map.fitBounds(bounds, { padding: [40, 40], maxZoom: 15 });
    }

    // Blindaje contra la carrera con las view transitions: si Leaflet midió
    // el contenedor durante la animación del swap, el tamaño queda mal y se
    // ven tiles grises/cortadas. Recalcular un par de veces lo corrige.
    const refit = () => {
      map.invalidateSize();
      if (bounds.length > 0) {
        map.fitBounds(bounds, { padding: [40, 40], maxZoom: 15 });
      }
    };
    setTimeout(refit, 250);
    setTimeout(refit, 800);
  };

  const initWhenReady = () => {
    // Esperar un frame: garantiza que el DOM nuevo ya está pintado
    requestAnimationFrame(() => setTimeout(setupMap, 0));
  };

  initWhenReady();
  document.addEventListener("astro:page-load", initWhenReady);
</script>
