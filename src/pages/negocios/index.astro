---
import Layout from "../../layouts/Layout.astro";
import Hero from "../../components/negocios/Hero.astro";
import CategoryFilter from "../../components/negocios/CategoryFilter.client";
import BusinessGrid from "../../components/negocios/BusinessGrid.client";
import { getBusinessesPage } from "../../lib/repositories/business.repository";
import { supabase } from "../../lib/supabase";

const PAGE_SIZE = 24;

// El listado se pagina en la base: acá viaja solo la PRIMERA tanda (SEO y
// primer paint); el resto lo pide BusinessGrid a /api/negocios al scrollear.
// Los filtros de la URL se respetan en el servidor para que una URL
// compartida (ej. ?categoria=gastronomia) cargue ya filtrada.
const categoria = Astro.url.searchParams.get("categoria");
const buscar = Astro.url.searchParams.get("buscar");

const [page, { data: categories }] = await Promise.all([
  getBusinessesPage({
    limit: PAGE_SIZE,
    categorySlug: categoria,
    search: buscar,
  }),
  supabase.from("categories").select("id, name, slug, icon").order("name"),
]);
---

<Layout
  title="Negocios y Servicios en El Talar"
  description="Guía de comercios y servicios de El Talar: horarios, teléfonos, WhatsApp y ubicación de los negocios del barrio."
>
  <Hero />
  <CategoryFilter categories={categories ?? []} client:load />
  <BusinessGrid
    initialItems={page.items}
    initialTotal={page.total}
    initialCategory={categoria}
    initialSearch={buscar}
    pageSize={PAGE_SIZE}
    client:load
  />
</Layout>
