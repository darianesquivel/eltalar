---
import Layout from "../../layouts/Layout.astro";
import { createSupabaseServer } from "../../lib/supabase/server";

const user = Astro.locals.user!;
const isAdmin = Astro.locals.isAdmin;

const supabase = createSupabaseServer(Astro);

// RLS: el owner solo ve sus negocios (el admin ve todos, pero acá filtramos por dueño)
const [{ data: businesses }, { data: myClaims }] = await Promise.all([
  supabase
    .from("businesses")
    .select("id, name, slug, status, is_active, is_featured")
    .eq("owner_id", user.id)
    .order("created_at", { ascending: false }),
  supabase
    .from("business_claims")
    .select("id, status, businesses ( name )")
    .eq("user_id", user.id)
    .eq("status", "pending"),
]);

const STATUS_BADGE: Record<string, { label: string; class: string }> = {
  pending: { label: "En revisión", class: "bg-yellow-100 text-yellow-700" },
  approved: { label: "Publicado", class: "bg-green-100 text-green-700" },
  rejected: { label: "Rechazado", class: "bg-red-100 text-red-700" },
};
---

<Layout title="Mi panel | El Talar">
  <section class="mx-auto w-full max-w-3xl space-y-8 py-8">
    <div class="flex flex-wrap items-center justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold">Mi panel</h1>
        <p class="text-sm text-gray-600">{user.email}</p>
      </div>

      <div class="flex items-center gap-3">
        {
          isAdmin && (
            <a
              href="/app/admin"
              class="rounded-full bg-secondary px-5 py-2 text-sm font-semibold text-white hover:opacity-90"
            >
              Panel admin
            </a>
          )
        }
        <form method="POST" action="/api/auth/signout">
          <button
            type="submit"
            class="rounded-full border border-gray-300 px-5 py-2 text-sm text-gray-600 hover:bg-gray-100"
          >
            Salir
          </button>
        </form>
      </div>
    </div>

    <div class="space-y-4">
      <div class="flex items-center justify-between">
        <h2 class="text-lg font-semibold">Mis negocios</h2>
        <a
          href="/app/negocios/nuevo"
          class="rounded-full bg-primary px-5 py-2 text-sm font-semibold text-white hover:bg-green-700"
        >
          + Cargar negocio
        </a>
      </div>

      {
        businesses && businesses.length > 0 ? (
          <ul class="space-y-3">
            {businesses.map((b) => {
              const badge = STATUS_BADGE[b.status] ?? STATUS_BADGE.pending;
              return (
                <li class="flex flex-wrap items-center justify-between gap-3 rounded-2xl bg-white p-5 shadow-sm">
                  <div class="flex items-center gap-3">
                    <span class="font-semibold">{b.name}</span>
                    <span
                      class={`rounded-full px-3 py-0.5 text-xs font-semibold ${badge.class}`}
                    >
                      {badge.label}
                    </span>
                    {b.is_featured && (
                      <span class="rounded-full bg-amber-100 px-3 py-0.5 text-xs font-semibold text-amber-700">
                        ⭐ Destacado
                      </span>
                    )}
                  </div>

                  <div class="flex gap-2">
                    {b.is_active && (
                      <a
                        href={`/negocios/${b.slug}`}
                        class="rounded-full border border-gray-200 px-4 py-1.5 text-sm text-gray-600 hover:bg-gray-50"
                      >
                        Ver ficha
                      </a>
                    )}
                    <a
                      href={`/app/negocios/${b.id}`}
                      class="rounded-full bg-primary/10 px-4 py-1.5 text-sm font-semibold text-primary hover:bg-primary/20"
                    >
                      Editar
                    </a>
                  </div>
                </li>
              );
            })}
          </ul>
        ) : (
          <div class="rounded-2xl border border-dashed p-10 text-center text-gray-500">
            <p class="mb-4">Todavía no cargaste ningún negocio.</p>
            <a
              href="/app/negocios/nuevo"
              class="rounded-full bg-primary px-6 py-2 font-semibold text-white hover:bg-green-700"
            >
              Cargar mi negocio
            </a>
          </div>
        )
      }
    </div>

    {
      myClaims && myClaims.length > 0 && (
        <div class="space-y-2">
          <h2 class="text-lg font-semibold">Reclamos en revisión</h2>
          <ul class="space-y-2">
            {myClaims.map((c) => (
              <li class="flex items-center gap-3 rounded-2xl bg-white p-4 text-sm shadow-sm">
                <span class="rounded-full bg-yellow-100 px-3 py-0.5 text-xs font-semibold text-yellow-700">
                  En revisión
                </span>
                {c.businesses?.name ?? "(negocio)"} — cuando lo verifiquemos va
                a aparecer en "Mis negocios".
              </li>
            ))}
          </ul>
        </div>
      )
    }

    <p class="text-xs text-gray-400">
      Los negocios nuevos y las modificaciones importantes pasan por una
      revisión rápida antes de publicarse.
    </p>
  </section>
</Layout>
