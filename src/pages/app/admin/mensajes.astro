---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import MessagesManager from "../../../components/app/MessagesManager";
import { createSupabaseServer } from "../../../lib/supabase/server";
import { getAdminBarrio } from "../../../lib/barrio";

const supabase = createSupabaseServer(Astro);
const barrio = await getAdminBarrio(Astro);

const { data: messages } = await supabase
  .from("contact_messages")
  .select("id, name, email, message, created_at")
  .eq("barrio_id", barrio.id)
  .order("created_at", { ascending: false });
---

<AdminLayout title="Mensajes">
  <div class="mx-auto max-w-3xl space-y-6">
    <div>
      <h1 class="text-2xl font-bold">Mensajes de vecinos</h1>
      <p class="text-sm text-gray-500">
        Todo lo que llega del formulario de contacto de la portada.
      </p>
    </div>

    <MessagesManager messages={messages ?? []} client:load />
  </div>
</AdminLayout>
