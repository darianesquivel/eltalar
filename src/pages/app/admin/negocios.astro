---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import AdminBusinesses from "../../../components/app/AdminBusinesses";
import { createSupabaseServer } from "../../../lib/supabase/server";

const supabase = createSupabaseServer(Astro);

const { data: businesses } = await supabase
  .from("businesses")
  .select("id, name, slug, address, status, is_active, is_featured, owner_id")
  .order("created_at", { ascending: false });
---

<AdminLayout title="Negocios">
  <div class="mx-auto flex h-full max-w-4xl flex-col gap-4">
    <div class="flex shrink-0 flex-wrap items-center justify-between gap-3">
      <h1 class="text-2xl font-bold">Negocios</h1>
      <a
        href="/app/negocios/nuevo"
        class="rounded-full bg-primary px-5 py-2 text-sm font-semibold text-white hover:bg-green-700"
      >
        + Cargar negocio
      </a>
    </div>

    <div class="min-h-0 flex-1">
      <AdminBusinesses businesses={businesses ?? []} client:load />
    </div>
  </div>
</AdminLayout>
