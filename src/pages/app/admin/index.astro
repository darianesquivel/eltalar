---
import AdminLayout from "../../../layouts/AdminLayout.astro";
import { createSupabaseServer } from "../../../lib/supabase/server";
import { getAdminBarrio } from "../../../lib/barrio";
import { todayInArgentina } from "../../../lib/hours";

// El middleware ya validó que sea admin
const supabase = createSupabaseServer(Astro);
const barrio = await getAdminBarrio(Astro);
const now = new Date().toISOString();
const today = todayInArgentina();

const count = (q: PromiseLike<{ count: number | null }>) =>
  Promise.resolve(q).then((r) => r.count ?? 0);

// Todos los números son DEL BARRIO elegido en el selector; reclamos y turnos
// no tienen barrio propio: se filtra por el del negocio (join !inner)
const [
  activos,
  pendientes,
  reclamos,
  mensajes,
  alertasActivas,
  turnosFuturos,
  conDueno,
  destacados,
  eventosVigentes,
  destacadosPagos,
  susActivas,
] = await Promise.all([
  count(
    supabase
      .from("businesses")
      .select("id", { count: "exact", head: true })
      .eq("barrio_id", barrio.id)
      .eq("is_active", true),
  ),
  count(
    supabase
      .from("businesses")
      .select("id", { count: "exact", head: true })
      .eq("barrio_id", barrio.id)
      .eq("status", "pending"),
  ),
  count(
    supabase
      .from("business_claims")
      .select("id, businesses!inner(barrio_id)", {
        count: "exact",
        head: true,
      })
      .eq("businesses.barrio_id", barrio.id)
      .eq("status", "pending"),
  ),
  count(
    supabase
      .from("contact_messages")
      .select("id", { count: "exact", head: true })
      .eq("barrio_id", barrio.id),
  ),
  count(
    supabase
      .from("site_alerts")
      .select("id", { count: "exact", head: true })
      .eq("barrio_id", barrio.id)
      .eq("is_active", true),
  ),
  count(
    supabase
      .from("pharmacy_turns")
      .select("id, businesses!inner(barrio_id)", {
        count: "exact",
        head: true,
      })
      .eq("businesses.barrio_id", barrio.id)
      .gt("ends_at", now),
  ),
  // Con dueño = reclamados + los que cargó el propio comerciante:
  // mide cuántos negocios ya se autogestionan
  count(
    supabase
      .from("businesses")
      .select("id", { count: "exact", head: true })
      .eq("barrio_id", barrio.id)
      .not("owner_id", "is", null),
  ),
  count(
    supabase
      .from("businesses")
      .select("id", { count: "exact", head: true })
      .eq("barrio_id", barrio.id)
      .eq("is_featured", true),
  ),
  // Mismo criterio de vigencia que la página pública /eventos
  count(
    supabase
      .from("events")
      .select("id", { count: "exact", head: true })
      .eq("barrio_id", barrio.id)
      .eq("is_active", true)
      .or(`end_date.gte.${today},and(end_date.is.null,date.gte.${today})`),
  ),
  // Destacados PAGOS: tienen featured_until (lo pone el webhook al cobrar);
  // los manuales del admin quedan sin fecha y no vencen
  count(
    supabase
      .from("businesses")
      .select("id", { count: "exact", head: true })
      .eq("barrio_id", barrio.id)
      .eq("is_featured", true)
      .not("featured_until", "is", null),
  ),
  // Suscripciones cobrándose ahora (una cancelada en período pagado sigue
  // destacada pero ya no cuenta acá)
  count(
    supabase
      .from("subscriptions")
      .select("id, businesses!inner(barrio_id)", {
        count: "exact",
        head: true,
      })
      .eq("businesses.barrio_id", barrio.id)
      .eq("status", "active"),
  ),
]);

// Uso vs límites del plan Free de Supabase (RPC admin_usage_stats).
// Si el RPC todavía no se corrió en la base, usage queda null y el panel
// muestra el aviso para correr el SQL.
const { data: usage } = await supabase.rpc("admin_usage_stats");

const MB = 1024 ** 2;
const GB = 1024 ** 3;
const fmtBytes = (b: number) =>
  b >= GB
    ? `${(b / GB).toFixed(2)} GB`
    : `${Math.max(1, Math.round(b / MB))} MB`;

// Semáforo: verde tranquilo, ámbar para mirar, rojo para actuar
const barColor = (pct: number) =>
  pct >= 90 ? "bg-red-500" : pct >= 70 ? "bg-amber-500" : "bg-green-500";

const limits = usage
  ? [
      {
        label: "Base de datos",
        detail: `${fmtBytes(usage.db_bytes)} de 500 MB`,
        pct: Math.min(100, (usage.db_bytes / (500 * MB)) * 100),
      },
      {
        label: "Fotos y archivos (Storage)",
        detail: `${fmtBytes(usage.storage_bytes)} de 1 GB`,
        pct: Math.min(100, (usage.storage_bytes / GB) * 100),
      },
      {
        label: "Usuarios activos del mes",
        detail: `${usage.mau.toLocaleString("es-AR")} de 50.000 (${usage.total_users.toLocaleString("es-AR")} registrados)`,
        pct: Math.min(100, (usage.mau / 50_000) * 100),
      },
    ]
  : null;

const limitsAttention = limits?.some((l) => l.pct >= 70) ?? false;

const CARDS = [
  {
    label: "Negocios publicados",
    value: activos,
    href: "/app/admin/negocios",
    accent: "text-green-600",
  },
  {
    label: "Esperando aprobación",
    value: pendientes,
    href: "/app/admin/negocios",
    accent: pendientes > 0 ? "text-yellow-600" : "text-gray-400",
    attention: pendientes > 0,
  },
  {
    label: "Con dueño (autogestionados)",
    value: conDueno,
    href: "/app/admin/negocios",
    accent: "text-blue-600",
  },
  {
    label: `Destacados ⭐ (${destacadosPagos} pagando · ${destacados - destacadosPagos} manuales)`,
    value: destacados,
    href: "/app/admin/negocios",
    accent: destacados > 0 ? "text-amber-500" : "text-gray-400",
  },
  {
    label: "Suscripciones activas",
    value: susActivas,
    href: "/app/admin/negocios",
    accent: susActivas > 0 ? "text-green-600" : "text-gray-400",
  },
  {
    label: "Reclamos pendientes",
    value: reclamos,
    href: "/app/admin/reclamos",
    accent: reclamos > 0 ? "text-blue-600" : "text-gray-400",
    attention: reclamos > 0,
  },
  {
    label: "Mensajes de vecinos",
    value: mensajes,
    href: "/app/admin/mensajes",
    accent: "text-gray-700",
  },
  {
    label: "Eventos vigentes",
    value: eventosVigentes,
    href: "/app/admin/eventos",
    accent: "text-violet-600",
  },
  {
    label: "Avisos activos",
    value: alertasActivas,
    href: "/app/admin/avisos",
    accent: "text-gray-700",
  },
  {
    label: "Turnos de farmacia cargados",
    value: turnosFuturos,
    href: "/app/admin/farmacias",
    accent: turnosFuturos === 0 ? "text-red-500" : "text-gray-700",
    attention: turnosFuturos === 0,
  },
];
---

<AdminLayout title="Dashboard">
  <div class="space-y-8">
    <div>
      <h1 class="text-2xl font-bold">Dashboard</h1>
      <p class="text-sm text-gray-500">
        El estado del sitio de un vistazo. Las tarjetas con punto necesitan tu
        atención.
      </p>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      {
        CARDS.map((card) => (
          <a
            href={card.href}
            class="relative rounded-2xl bg-white p-6 shadow-sm transition hover:shadow-md"
          >
            {card.attention && (
              <span class="absolute right-4 top-4 h-2.5 w-2.5 animate-pulse rounded-full bg-red-500" />
            )}
            <p class={`text-3xl font-bold ${card.accent}`}>{card.value}</p>
            <p class="mt-1 text-sm text-gray-500">{card.label}</p>
          </a>
        ))
      }
    </div>

    <div class="relative rounded-2xl bg-white p-6 shadow-sm">
      {
        limitsAttention && (
          <span class="absolute right-4 top-4 h-2.5 w-2.5 animate-pulse rounded-full bg-red-500" />
        )
      }
      <h2 class="text-lg font-semibold">Límites del plan gratuito</h2>
      <p class="mb-4 text-xs text-gray-400">
        Mientras estas barras estén en verde, el sitio cuesta $0. Supabase Free
        no factura: si un límite se llena, el servicio se frena.
      </p>

      {
        limits ? (
          <div class="space-y-4">
            {limits.map((l) => (
              <div>
                <div class="mb-1 flex items-baseline justify-between gap-2 text-sm">
                  <span class="font-medium text-gray-700">{l.label}</span>
                  <span class="text-xs tabular-nums text-gray-500">
                    {l.detail} · {Math.round(l.pct)}%
                  </span>
                </div>
                <div class="h-2 overflow-hidden rounded-full bg-gray-100">
                  <div
                    class={`h-full rounded-full ${barColor(l.pct)}`}
                    style={`width: ${Math.max(1, l.pct)}%`}
                  />
                </div>
              </div>
            ))}
          </div>
        ) : (
          <p class="rounded-xl bg-amber-50 p-4 text-sm text-amber-700">
            Falta habilitar la función en la base: corré{" "}
            <code class="font-mono text-xs">
              docs/sql/2026-07-12-admin-usage-stats.sql
            </code>{" "}
            en el SQL Editor de Supabase.
          </p>
        )
      }

      <p class="mt-4 text-xs text-gray-400">
        Lo que no se puede medir desde acá (revisar una vez por mes): tráfico de{
          " "
        }
        <a
          href="https://supabase.com/dashboard/project/_/settings/billing/usage"
          target="_blank"
          rel="noopener noreferrer"
          class="underline hover:text-gray-600"
        >
          Supabase
        </a>{" "}
        (5 GB/mes), ancho de banda de{" "}
        <a
          href="https://vercel.com/dashboard"
          target="_blank"
          rel="noopener noreferrer"
          class="underline hover:text-gray-600"
        >
          Vercel
        </a>{" "}
        (100 GB/mes) y cuota de{" "}
        <a
          href="https://console.cloud.google.com/google/maps-apis/quotas"
          target="_blank"
          rel="noopener noreferrer"
          class="underline hover:text-gray-600"
        >
          Google Places
        </a>{" "}
        (la única con tarjeta: ponele límite de cuota).
      </p>
    </div>

    <div class="rounded-2xl bg-white p-6 shadow-sm">
      <h2 class="mb-3 text-lg font-semibold">Acciones rápidas</h2>
      <div class="flex flex-wrap gap-3">
        <a
          href="/app/negocios/nuevo"
          class="rounded-full bg-primary px-5 py-2 text-sm font-semibold text-white hover:bg-green-700"
        >
          + Cargar negocio
        </a>
        <a
          href="/app/admin/farmacias"
          class="rounded-full bg-gray-100 px-5 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-200"
        >
          + Cargar turno de farmacia
        </a>
        <a
          href="/app/admin/avisos"
          class="rounded-full bg-gray-100 px-5 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-200"
        >
          + Publicar aviso
        </a>
        <a
          href="/app/admin/telefonos"
          class="rounded-full bg-gray-100 px-5 py-2 text-sm font-semibold text-gray-700 hover:bg-gray-200"
        >
          + Agregar teléfono útil
        </a>
      </div>
    </div>
  </div>
</AdminLayout>
