---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/home/Hero.astro";
import Alerts from "../components/home/Alerts.astro";
import QuickAccess from "../components/home/QuickAccess.astro";
import FeaturedBusinesses from "../components/home/FeaturedBusinesses.astro";
import Contact from "../components/home/Contact.astro";
import { getBusinesses } from "../lib/repositories/business.repository";
import { supabase } from "../lib/supabase";

const { barrio } = Astro.locals;

// Un solo round-trip: avisos y destacados en paralelo (antes eran en serie,
// cada componente esperando al anterior).
const [{ data: alerts }, featured] = await Promise.all([
  supabase
    .from("site_alerts")
    .select("id, title, description")
    .eq("barrio_id", barrio.id)
    .eq("is_active", true)
    .order("created_at", { ascending: false }),
  getBusinesses({ barrioId: barrio.id, featured: true, limit: 6 }),
]);
---

<Layout>
  <Hero />
  <Alerts alerts={alerts ?? []} />
  <QuickAccess />
  <FeaturedBusinesses businesses={featured} />
  <Contact />
</Layout>
