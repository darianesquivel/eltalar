---
import { Phone } from "@lucide/astro";
import MapPreview from "../MapPreview.astro";

interface Props {
  name: string;
  address?: string;
  badge?: string;
  subtitle?: string;
  phone?: string | null;
  whatsapp?: string | null;
  highlight?: boolean;
}

const {
  name,
  address,
  badge,
  subtitle,
  phone,
  whatsapp,
  highlight = false,
} = Astro.props;
---

<div class={"flex flex-col gap-2 rounded-2xl bg-white p-6 shadow-sm"}>
  {
    badge && (
      <span
        class={`inline-flex w-fit items-center rounded-full px-3 py-1 text-xs font-semibold ${
          highlight
            ? "bg-green-100 text-green-700"
            : "bg-gray-100 text-gray-700"
        }`}
      >
        {badge}
      </span>
    )
  }

  {subtitle && <p class="text-sm font-semibold text-green-600">{subtitle}</p>}

  <h3 class="text-2xl font-bold text-gray-900">{name}</h3>

  {address && <p class="text-sm text-gray-600">📍 {address}</p>}

  {
    (phone || whatsapp) && (
      <div class="flex flex-wrap gap-3">
        {phone && (
          <a
            href={`tel:${phone}`}
            class={`rounded-full px-5 py-2 text-sm font-semibold flex items-center gap-2 ${
              highlight
                ? "bg-green-500 text-white"
                : "bg-gray-100 text-gray-800"
            }`}
          >
            <Phone size={15} />
            Llamar
          </a>
        )}

        {whatsapp && (
          <a
            href={`https://wa.me/${whatsapp}`}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full bg-gray-100 px-5 py-2 text-sm font-semibold text-gray-800"
          >
            💬 WhatsApp
          </a>
        )}
      </div>
    )
  }
  <MapPreview address={address} />
</div>
