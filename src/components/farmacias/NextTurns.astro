---
import { supabase } from "../../lib/supabase";
import { ARGENTINA_TZ } from "../../lib/hours";
import PharmacyCard from "./PharmacyCard.astro";

const now = new Date().toISOString();

// El barrio del turno viene implícito por la farmacia (join !inner)
const { data: nextTurns, error } = await supabase
  .from("pharmacy_turns")
  .select(
    `
    starts_at,
    businesses!inner (
      name,
      address,
      phone
    )
    `,
  )
  .eq("businesses.barrio_id", Astro.locals.barrio.id)
  .gt("starts_at", now)
  .order("starts_at", { ascending: true })
  .limit(6);

if (error) {
  console.error("Error próximos turnos:", error);
}

const formatDay = (date: string) =>
  new Date(date)
    .toLocaleDateString("es-AR", { weekday: "long", timeZone: ARGENTINA_TZ })
    .toUpperCase();

const formatDate = (date: string) =>
  new Date(date).toLocaleDateString("es-AR", {
    day: "numeric",
    timeZone: ARGENTINA_TZ,
  });

const hasTurns = nextTurns && nextTurns.length > 0;
---

<section>
  <div class="mb-6 flex items-center justify-between">
    <h2 id="farmacias-proximos-turnos" class="text-2xl font-bold">
      Próximos Turnos
    </h2>
  </div>

  {
    hasTurns ? (
      <div class="grid gap-6 md:grid-cols-3">
        {nextTurns.map((turn) => {
          const business = Array.isArray(turn.businesses)
            ? turn.businesses[0]
            : turn.businesses;

          return (
            <PharmacyCard
              name={business.name}
              address={business.address}
              badge={`📅 ${formatDay(turn.starts_at)} ${formatDate(
                turn.starts_at,
              )}`}
            />
          );
        })}
      </div>
    ) : (
      <div class="rounded-2xl bg-gray-50 p-6 text-center text-gray-500">
        No hay turnos próximos cargados.
      </div>
    )
  }
</section>
