---
import { Phone } from "@lucide/astro";

interface Props {
  title: string;
  subtitle?: string | null;
  phone: string; // número completo y marcable (+54..., 0800..., 911)
}

const { title, subtitle, phone } = Astro.props;
---

<div
  class="flex flex-col gap-3 justify-between items-center rounded-2xl border border-blue-100 p-6"
>
  <h3 class="text-lg font-bold">{title}</h3>
  {subtitle && <p class="text-sm text-gray-600">{subtitle}</p>}

  <a
    href={`tel:${phone}`}
    class="inline-flex w-fit items-center justify-center gap-2 rounded-full bg-primary py-1 px-5 font-semibold text-white"
  >
    <Phone size={15} /> Llamar
  </a>
</div>
