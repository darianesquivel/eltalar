---
import { Phone } from "@lucide/astro";

const { barrio } = Astro.locals;
---

<section
  class="relative overflow-hidden flex justify-center items-center py-20 rounded-3xl"
>
  <div class="absolute inset-0 bg-linear-to-tr from-red-100 via-white to-white">
  </div>

  <div class="relative mx-auto max-w-4xl px-6 text-center flex flex-col gap-6">
    <span
      class="animate-fade-up mx-auto inline-flex items-center gap-2 rounded-full bg-red-100 px-4 py-1 text-xs font-semibold text-red-700"
    >
      <Phone size={14} />
      Teléfonos útiles
    </span>

    <h1
      class="animate-fade-up text-4xl md:text-5xl font-extrabold tracking-tight text-gray-900"
      style="animation-delay: 0.12s"
    >
      Teléfonos que{" "}
      <span class="text-red-600">importan</span>
    </h1>

    <p
      class="animate-fade-up mx-auto max-w-2xl text-lg text-gray-600"
      style="animation-delay: 0.24s"
    >
      Conectamos a los vecinos de <span class="font-medium">{barrio.name}</span> con
      servicios esenciales, emergencias y atención rápida cuando más se necesita.
    </p>

    <div
      class="animate-fade-up flex justify-center gap-4"
      style="animation-delay: 0.36s"
    >
      <a
        href="#emergencias"
        class="rounded-full bg-red-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:scale-105 transition-transform"
      >
        Emergencias
      </a>

      <a
        href="#telefonos"
        class="rounded-full border border-gray-300 px-6 py-3 text-sm font-semibold text-gray-700 hover:bg-gray-100 transition"
      >
        Ver teléfonos
      </a>
    </div>
  </div>
</section>
