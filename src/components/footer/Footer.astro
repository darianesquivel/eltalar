---
import Logo from "../../assets/logo.svg";

const { barrio } = Astro.locals;
---

<footer class="bg-secondary-soft">
  <div class="mx-auto max-w-6xl px-6 py-10">
    <div
      class="flex flex-col gap-6 md:flex-row items-center md:justify-between"
    >
      <div class="flex flex-col items-center sm:items-start">
        <img src={Logo.src} alt="" class="w-17" />
        <p class="mt-2 text-sm text-text-inverted">
          Hecho con ❤️ para los vecinos de {barrio.name}.
        </p>
      </div>

      <nav class="flex flex-wrap items-center justify-center gap-x-6 gap-y-2">
        <a
          href="/negocios"
          class="text-sm text-text-inverted/80 hover:text-white"
        >
          Negocios
        </a>
        <a
          href="/farmacias"
          class="text-sm text-text-inverted/80 hover:text-white"
        >
          Farmacias
        </a>
        <a
          href="/telefonos"
          class="text-sm text-text-inverted/80 hover:text-white"
        >
          Teléfonos
        </a>
        <a href="/mapa" class="text-sm text-text-inverted/80 hover:text-white">
          Mapa
        </a>
        <a
          href="/anunciate"
          class="rounded-full bg-amber-500/90 px-4 py-1.5 text-sm font-semibold text-white hover:bg-amber-500"
        >
          ⭐ Anunciá tu negocio
        </a>
      </nav>
    </div>

    <div class="mt-8 text-center text-xs text-text-inverted">
      © {new Date().getFullYear()}
      {barrio.name}. Todos los derechos reservados.
    </div>
  </div>
</footer>
