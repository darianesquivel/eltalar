---
// Los avisos llegan por props: la home los busca en paralelo con los
// destacados (antes cada componente esperaba su propia consulta en serie).
type Alert = { id: string; title: string; description: string | null };

interface Props {
  alerts: Alert[];
}

const { alerts } = Astro.props;
const hasAlerts = alerts.length > 0;
---

<section class="mx-auto max-w-6xl px-6 space-y-3">
  {
    hasAlerts ? (
      alerts.map((alert) => (
        <div
          class="
            flex flex-col gap-1
            sm:flex-row items-center sm:gap-3
            rounded-xl bg-blue-100 px-4 py-3
            text-sm text-blue-800
          "
        >
          <span
            class="
              font-semibold
              sm:whitespace-nowrap
            "
          >
            {alert.title}
          </span>

          <span class="text-blue-700">{alert.description}</span>
        </div>
      ))
    ) : (
      <div
        class=" flex flex-col gap-1
            sm:flex-row sm:gap-3
            items-center rounded-xl bg-gray-100 px-4 py-3 text-sm text-gray-600"
      >
        <span class="font-semibold">Información</span>
        <span>No hay avisos importantes en este momento.</span>
      </div>
    )
  }
</section>
