---
import { MailCheck } from "@lucide/astro";
import Logo from "../../assets/logo.svg";
---

<section id="contact" class="flex justify-center w-full">
  <div
    id="contact-container"
    class="relative flex w-full max-w-4xl flex-col gap-12 rounded-3xl bg-white p-8 shadow-sm md:flex-row md:items-center md:p-12 overflow-hidden"
  >
    <div
      id="success-overlay"
      class="absolute inset-0 z-20 flex flex-col items-center justify-center bg-white opacity-0 pointer-events-none transition-all duration-500"
    >
      <div
        id="success-check"
        class="mb-6 scale-50 text-green-600 transition-transform duration-500"
        style="font-size: 6rem"
      >
        <MailCheck size={72} />
      </div>

      <h3 class="text-2xl font-bold text-gray-900 mb-2">
        ¡Gracias por escribirnos!
      </h3>
      <p class="text-center text-gray-600 max-w-sm">
        Recibimos tu mensaje correctamente. En breve nos estaremos comunicando
        con vos.
      </p>
    </div>

    <div
      id="contact-content"
      class="flex flex-1 flex-col gap-5 transition-opacity duration-300"
    >
      <div class="flex flex-col items-center gap-5 text-center">
        <img src={Logo.src} alt="Logo" class="w-16" />
        <h2 class="text-2xl font-bold text-gray-900 md:text-3xl">
          ¿Tenés alguna sugerencia?
        </h2>
      </div>

      <p class="text-gray-600">
        Este portal se construye entre todos. Queremos que sea útil, claro y
        actualizado.
      </p>

      <ul class="space-y-2 text-gray-700">
        <li class="flex gap-3">
          <span class="text-primary">✔</span>
          Si encontrás un error o falta información
        </li>
        <li class="flex gap-3">
          <span class="text-primary">✔</span>
          Si querés publicar tu negocio o servicio
        </li>
        <li class="flex gap-3">
          <span class="text-primary">✔</span>
          Si tenés una idea para mejorar la página
        </li>
      </ul>

      <p class="text-gray-600">
        Escribinos y ayudanos a seguir mejorando este espacio para toda la
        comunidad.
      </p>
    </div>

    <form
      id="contact-form"
      class="flex flex-1 flex-col gap-5 rounded-2xl bg-gray-50 p-6 transition-opacity duration-300"
    >
      <input
        name="name"
        required
        placeholder="Tu nombre"
        class="rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
      />

      <input
        name="email"
        type="email"
        required
        placeholder="tu@email.com"
        class="rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
      />

      <textarea
        name="message"
        required
        rows="4"
        placeholder="Mensaje"
        class="resize-none rounded-xl border border-gray-200 bg-white px-4 py-3 text-sm focus:border-primary focus:outline-none focus:ring-2 focus:ring-primary/20"
      ></textarea>

      <input
        type="text"
        name="company"
        tabindex="-1"
        autocomplete="off"
        class="hidden"
      />

      <button
        id="submit-btn"
        type="submit"
        class="rounded-xl bg-primary px-6 py-3 text-sm font-semibold text-white transition hover:bg-green-700 disabled:opacity-60"
      >
        Enviar mensaje
      </button>
    </form>
  </div>
</section>

<script is:inline>
  const form = document.getElementById("contact-form");
  const button = document.getElementById("submit-btn");
  const overlay = document.getElementById("success-overlay");
  const check = document.getElementById("success-check");
  const content = document.getElementById("contact-content");

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    button.disabled = true;
    button.textContent = "Enviando…";

    const data = new FormData(form);

    try {
      // El honeypot ("company") viaja al servidor, que es quien decide:
      // un bot que postee directo a la API ya no puede saltearse el chequeo.
      const res = await fetch("/api/contact", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          name: data.get("name"),
          email: data.get("email"),
          message: data.get("message"),
          company: data.get("company"),
        }),
      });

      if (!res.ok) throw new Error();

      form.style.opacity = "0";
      content.style.opacity = "0";

      setTimeout(() => {
        overlay.classList.remove("pointer-events-none");
        overlay.style.opacity = "1";
        check.style.transform = "scale(1)";
      }, 300);
    } catch {
      button.disabled = false;
      button.textContent = "Enviar mensaje";
      alert("Error al enviar el mensaje 😞");
    }
  });
</script>
