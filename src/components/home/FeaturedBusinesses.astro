---
import { Star, ArrowRight } from "@lucide/astro";
import BusinessCard from "../negocios/BusinessCard";
import type { Business } from "../../lib/repositories/business.repository";

interface Props {
  businesses: Business[];
}

const { businesses: featuredBusinesses } = Astro.props;
---

<section class="mx-auto w-full max-w-6xl px-2 sm:px-6">
  <div
    class="relative overflow-hidden rounded-3xl bg-white px-6 py-14 shadow-sm"
  >
    <!-- resplandor cálido, sutil, solo arriba -->
    <div
      class="pointer-events-none absolute inset-x-0 -top-24 h-56 bg-linear-to-b from-amber-100/70 via-amber-50/40 to-transparent"
    >
    </div>

    <div class="relative flex flex-col items-center gap-10">
      <div class="flex flex-col items-center gap-3 text-center">
        <span
          class="inline-flex items-center gap-1.5 rounded-full border border-amber-200 bg-amber-50 px-3.5 py-1 text-[11px] font-semibold uppercase tracking-[0.15em] text-amber-600"
        >
          <Star size={12} fill="currentColor" />
          Destacados
        </span>
        <h2 class="text-2xl font-bold text-gray-900 md:text-3xl">
          Los comercios que apuestan por el barrio
        </h2>
        <p class="max-w-xl text-sm text-gray-500">
          Negocios de El Talar con lugar preferencial en el portal. Tu apoyo los
          mantiene creciendo — y ellos mantienen esta página gratuita.
        </p>
      </div>

      <div
        class="grid w-full gap-6 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4"
      >
        {
          featuredBusinesses?.map((business) => (
            <BusinessCard business={business} client:visible />
          ))
        }
      </div>

      <div class="flex flex-col items-center gap-3 sm:flex-row">
        <a
          href="/negocios"
          class="rounded-full border border-gray-200 bg-white px-6 py-2.5 text-sm font-semibold text-gray-600 transition hover:border-gray-300 hover:text-gray-900"
        >
          Ver todos los negocios
        </a>
        <a
          href="/anunciate"
          class="group inline-flex items-center gap-2 rounded-full bg-gray-900 px-6 py-2.5 text-sm font-semibold text-white transition-all hover:scale-[1.03] hover:bg-gray-800"
        >
          <Star size={15} class="text-amber-400" fill="currentColor" />
          Quiero destacar mi negocio
          <ArrowRight
            size={15}
            class="transition-transform group-hover:translate-x-0.5"
          />
        </a>
      </div>
    </div>
  </div>
</section>
