---
import { Share, Copy, Check } from "@lucide/astro";

const { url, title } = Astro.props;
---

<div class="rounded-2xl bg-green-50 p-6 text-center space-y-3">
  <p class="text-sm text-gray-700">
    ¿Te gusta este lugar?
    <br />
    Compartilo con tus vecinos
  </p>

  <div class="flex justify-center gap-4">
    <button
      id="share-btn"
      class="flex gap-1 items-center justify-center rounded-full px-5 py-2 bg-white shadow transition hover:scale-105 text-xs"
      aria-label="Compartir negocio"
      title="Compartir"
    >
      <Share size={20} />
      Compartir!
    </button>

    <button
      id="copy-btn"
      class="flex gap-1 items-center justify-center rounded-full px-5 py-2 bg-white shadow transition hover:scale-105 text-xs"
      aria-label="Copiar link"
      title="Copiar link"
    >
      <Copy size={20} />
      Copiar Link!
    </button>
  </div>

  <p
    id="copy-feedback"
    class="text-xs flex gap-2 items-center justify-center text-green-700 opacity-0 transition-opacity"
  >
    Link copiado
    <Check size={12} />
  </p>
</div>

<script is:inline data-astro-rerun define:vars={{ url, title }}>
  const shareBtn = document.getElementById("share-btn");
  const copyBtn = document.getElementById("copy-btn");
  const feedback = document.getElementById("copy-feedback");

  function showFeedback() {
    feedback.classList.remove("opacity-0");
    setTimeout(() => {
      feedback.classList.add("opacity-0");
    }, 2000);
  }

  shareBtn?.addEventListener("click", async () => {
    if (navigator.share) {
      try {
        await navigator.share({
          title,
          url,
        });
      } catch (e) {
        // usuario canceló
      }
    } else {
      await navigator.clipboard.writeText(url);
      showFeedback();
    }
  });

  copyBtn?.addEventListener("click", async () => {
    await navigator.clipboard.writeText(url);
    showFeedback();
  });
</script>
