---
import { Image } from "astro:assets";
import {
  Info,
  PhoneCall,
  Clock,
  ArrowLeft,
  Flame,
  ClipboardList,
  Check,
} from "@lucide/astro";
import CategoryPlaceholder from "./CategoryPlaceholder";
import ReportBusiness from "./ReportBusiness";
import InstagramIcon from "../icons/InstagramIcon";
import MapPreview from "../MapPreview.astro";
import ShareBusiness from "./ShareBusiness.astro";
import { getWeekSchedule } from "../../lib/hours";
import type { Business } from "../../lib/repositories/business.repository";

interface Props {
  business: Business;
}

const { business } = Astro.props;
const hours = getWeekSchedule(business.business_hours);

// Lista de servicios y precios (beneficio Destacado): un item por linea
const serviceLines = (business.services ?? "")
  .split("\n")
  .map((l) => l.trim())
  .filter(Boolean);

// Galería: fotos extra además de la portada (las tienen los Destacados,
// que pueden subir hasta 4). Se muestran debajo de la imagen principal.
const galleryPhotos = (business.photos ?? []).filter(
  (p) => p.id !== business.coverPhoto?.id,
);

const whatsappLogo = "/images/whatsapp-icon.svg";

// URL absoluta para compartir, derivada del dominio configurado en astro.config.
const shareUrl = new URL(
  `/negocios/${business.slug}`,
  Astro.site ?? Astro.url,
).toString();
---

<section
  id="business-detail"
  data-business-id={business.id}
  class="max-w-6xl mx-auto px-4 space-y-8"
>
  <a
    href="/negocios"
    class="inline-flex items-center gap-2 text-sm text-primary hover:underline"
  >
    <ArrowLeft size={18} /> Volver a negocios
  </a>

  <div class="relative overflow-hidden rounded-3xl shadow">
    {
      business.coverPhoto?.url ? (
        <Image
          transition:name={`img-${business.slug}`}
          src={business.coverPhoto.url}
          alt={business.name}
          width={1280}
          height={540}
          widths={[480, 800, 1280]}
          sizes="100vw"
          loading="eager"
          class="h-[260px] w-full object-cover md:h-[540px]"
        />
      ) : (
        <div transition:name={`img-${business.slug}`}>
          <CategoryPlaceholder
            categorySlug={business.categories?.[0]?.slug}
            label={business.name}
            iconSize={72}
            className="h-[260px] w-full md:h-[540px]"
          />
        </div>
      )
    }

    <div
      class="absolute inset-0 bg-linear-to-t from-black/70 via-black/30 to-transparent"
    >
    </div>

    <div class="absolute bottom-6 left-6 text-white space-y-2">
      <div class="flex flex-wrap gap-2">
        {
          business.is_featured && (
            <span class="inline-flex items-center gap-1 rounded-full border border-amber-300/60 bg-amber-400/90 px-3 py-0.5 text-xs font-semibold text-amber-950">
              ⭐ Destacado
            </span>
          )
        }
        {
          business.categories.map((category) => (
            <span class="text-xs px-2 bg-primary border border-white/30 text-white rounded-full">
              {category.name}
            </span>
          ))
        }
      </div>

      <h1 class="text-3xl font-bold md:text-4xl">
        {business.name}
      </h1>
    </div>
  </div>

  <div class="grid gap-6 md:grid-cols-3">
    <div class="md:col-span-2 space-y-6">
      <div class="rounded-2xl bg-white p-6 shadow-sm">
        <h2 class="mb-3 text-lg font-semibold flex items-center gap-2">
          <Info size={24} class="text-primary" />
          Sobre el comercio
        </h2>
        <p class="text-gray-600 whitespace-pre-line">
          {business.description}
        </p>
      </div>

      {
        business.offers.length > 0 && (
          <div class="space-y-3">
            {business.offers.map((offer) => (
              <div class="flex items-start gap-3 rounded-2xl border border-orange-200 bg-linear-to-r from-orange-50 to-amber-50 p-5">
                <Flame size={22} class="mt-0.5 shrink-0 text-orange-500" />
                <div>
                  <p class="font-semibold text-gray-900">{offer.title}</p>
                  {offer.description && (
                    <p class="mt-0.5 text-sm text-gray-600">
                      {offer.description}
                    </p>
                  )}
                  <p class="mt-1 text-xs font-medium text-orange-600">
                    Válida hasta el{" "}
                    {new Date(
                      `${offer.expires_at}T12:00:00`,
                    ).toLocaleDateString("es-AR", {
                      day: "numeric",
                      month: "long",
                    })}
                  </p>
                </div>
              </div>
            ))}
          </div>
        )
      }

      <div class="flex gap-2 items-center">
        {
          business.whatsapp && (
            <a
              href={`https://wa.me/${business.whatsapp}`}
              target="_blank"
              rel="noopener noreferrer"
              data-track="whatsapp"
              class="flex-1 h-15 text-xs flex items-center gap-1 justify-center transition-transform duration-200 hover:scale-105 bg-primary text-white px-5 py-1 rounded-lg"
            >
              <img width={20} src={whatsappLogo} alt="" /> Whatsapp
            </a>
          )
        }

        {
          business.instagram && (
            <a
              href={business.instagram}
              target="_blank"
              rel="noopener noreferrer"
              data-track="instagram"
              class="flex-1 h-15 inline-flex items-center justify-center transition-transform duration-300 hover:scale-105 bg-secondary-soft/10 hover:bg-secondary-soft/30 p-1 rounded-lg"
            >
              <InstagramIcon size={20} className="text-gray-700" />
            </a>
          )
        }

        {
          business.phone && (
            <a
              href={`tel:${business.phone}`}
              data-track="phone"
              class="flex-1 h-15 inline-flex items-center justify-center transition-transform duration-200 hover:scale-105 bg-secondary-soft/10 hover:bg-secondary-soft/30 p-1 rounded-lg"
              aria-label="Llamar por teléfono"
            >
              <PhoneCall size={20} class="text-gray-700" />
            </a>
          )
        }
      </div>

      {
        galleryPhotos.length > 0 && (
          <div class="grid grid-cols-3 gap-3">
            {galleryPhotos.map((photo) => (
              <a
                href={photo.url}
                target="_blank"
                rel="noopener noreferrer"
                class="block overflow-hidden rounded-xl shadow-sm transition-transform hover:scale-[1.02]"
              >
                <Image
                  src={photo.url}
                  alt={`Foto de ${business.name}`}
                  width={480}
                  height={320}
                  loading="lazy"
                  class="h-32 w-full object-cover md:h-40"
                />
              </a>
            ))}
          </div>
        )
      }

      {
        serviceLines.length > 0 && (
          <div class="rounded-2xl bg-white p-6 shadow-sm">
            <h2 class="mb-3 text-lg font-semibold flex items-center gap-2">
              <ClipboardList size={24} class="text-primary" />
              Servicios y precios
            </h2>
            <ul class="grid gap-2 sm:grid-cols-2">
              {serviceLines.map((line) => (
                <li class="flex items-start gap-2 text-sm text-gray-700">
                  <Check size={15} class="mt-0.5 shrink-0 text-primary" />
                  {line}
                </li>
              ))}
            </ul>
          </div>
        )
      }

      <MapPreview address={business.address} />
    </div>

    <div class="space-y-6">
      <div class="rounded-2xl bg-white p-6 shadow-sm">
        <h2 class="mb-4 text-lg font-semibold flex items-center gap-2">
          <Clock size={24} class="text-primary" />
          {business.by_appointment ? "Atención" : "Horarios"}
        </h2>

        {
          business.by_appointment && (
            <div class="space-y-1 rounded-xl bg-primary-soft/40 p-4 text-sm">
              <p class="font-semibold text-gray-800">📅 Atiende con turno</p>
              <p class="text-gray-600">
                Escribile o llamalo para coordinar un turno.
              </p>
            </div>
          )
        }

        {!business.by_appointment && (
        <ul class="space-y-2 text-sm">
          {
            hours.map((day) => (
              <li class="flex justify-between items-start gap-4">
                <span class={day.isToday ? "font-semibold text-green-600" : ""}>
                  {day.label}
                  {day.isToday && (
                    <span class="ml-1 rounded bg-green-100 px-2 text-xs">
                      HOY
                    </span>
                  )}
                </span>

                <div
                  class={
                    day.status === "closed"
                      ? "text-red-500 text-right"
                      : day.status === "not_loaded"
                        ? "text-gray-400 text-right"
                        : "text-gray-700 text-right"
                  }
                >
                  {day.status === "open_24" && <span>Abierto 24hs</span>}

                  {day.status === "open" &&
                    day.ranges?.map((r) => (
                      <span class="block">
                        {r.open} – {r.close}
                      </span>
                    ))}

                  {day.status === "closed" && <span>Cerrado</span>}
                  {day.status === "not_loaded" && <span>—</span>}
                </div>
              </li>
            ))
          }
        </ul>
        )}
      </div>

      <!-- COMPARTIR -->
      <ShareBusiness url={shareUrl} title={business.name} />

      {
        !business.owner_id && (
          <div class="rounded-2xl border border-dashed border-primary/40 bg-primary-soft/40 p-5 text-center space-y-2">
            <p class="text-sm font-semibold text-gray-800">
              ¿Este negocio es tuyo?
            </p>
            <p class="text-xs text-gray-600">
              Reclamalo y gestioná vos mismo las fotos, horarios y datos de
              contacto.
            </p>
            <a
              href={`/app/reclamar/${business.id}`}
              class="inline-block rounded-full bg-primary px-5 py-2 text-sm font-semibold text-white transition hover:bg-green-700"
            >
              Reclamar mi negocio
            </a>
          </div>
        )
      }

      <!-- REPORTAR ERROR: los vecinos ayudan a curar los datos -->
      <ReportBusiness
        slug={business.slug}
        businessName={business.name}
        client:visible
      />
    </div>
  </div>
</section>

<script>
  import { track, type TrackEvent } from "../../lib/track";

  // Patrón page-load: con el ClientRouter los module scripts corren una vez
  // por sesión; el setup debe re-ejecutarse en cada navegación.
  const setupTracking = () => {
    const root = document.getElementById("business-detail");
    if (!root || root.dataset.tracked) return;
    root.dataset.tracked = "1";

    const businessId = root.dataset.businessId!;

    // Vista de ficha (corre solo en visitas reales, no en prefetch)
    track(businessId, "view");

    // Clicks a los botones de contacto
    root.querySelectorAll<HTMLElement>("[data-track]").forEach((el) => {
      el.addEventListener("click", () => {
        track(businessId, el.dataset.track as TrackEvent);
      });
    });
  };

  setupTracking();
  document.addEventListener("astro:page-load", setupTracking);
</script>
