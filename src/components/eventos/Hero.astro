---
import { PartyPopper } from "@lucide/astro";

const { barrio } = Astro.locals;
---

<section
  class="relative overflow-hidden flex justify-center items-center py-20 rounded-3xl"
>
  <div
    class="absolute inset-0 bg-linear-to-tr from-violet-100 via-white to-white"
  >
  </div>

  <div class="relative mx-auto max-w-4xl px-6 text-center flex flex-col gap-6">
    <span
      class="animate-fade-up mx-auto inline-flex items-center gap-2 rounded-full bg-violet-100 px-4 py-1 text-xs font-semibold text-violet-700"
    >
      <PartyPopper size={14} />
      Agenda del barrio
    </span>

    <h1
      class="animate-fade-up text-4xl md:text-5xl font-extrabold tracking-tight text-gray-900"
      style="animation-delay: 0.12s"
    >
      Eventos de{" "}
      <span class="text-violet-600">{barrio.name}</span>
    </h1>

    <p
      class="animate-fade-up mx-auto max-w-2xl text-lg text-gray-600"
      style="animation-delay: 0.24s"
    >
      Ferias, festivales y actividades del barrio: qué está pasando y qué se
      viene, con día, horario y lugar.
    </p>

    <div
      class="animate-fade-up flex justify-center gap-4"
      style="animation-delay: 0.36s"
    >
      <a
        href="#eventos"
        class="rounded-full bg-violet-600 px-6 py-3 text-sm font-semibold text-white shadow-sm hover:scale-105 transition-transform"
      >
        Ver eventos
      </a>
    </div>
  </div>
</section>
