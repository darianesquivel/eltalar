---
import { ClientRouter } from "astro:transitions";
import {
  LayoutDashboard,
  Store,
  UserCheck,
  Megaphone,
  Phone,
  Pill,
  Tags,
  Mail,
  Globe,
  LogOut,
  CalendarDays,
} from "@lucide/astro";
import NavLoader from "../components/NavLoader.astro";
import {
  getAdminBarrio,
  listBarrios,
  ADMIN_BARRIO_COOKIE,
} from "../lib/barrio";

import "../styles/global.css";

interface Props {
  title: string;
}

const { title } = Astro.props;
const path = Astro.url.pathname;

// Superadmin multi-barrio: sobre qué barrio trabaja el panel (cookie) y la
// lista para el selector (solo se muestra si hay más de un barrio)
const [adminBarrio, barrios] = await Promise.all([
  getAdminBarrio(Astro),
  listBarrios(),
]);

const NAV = [
  {
    href: "/app/admin",
    label: "Dashboard",
    icon: LayoutDashboard,
    exact: true,
  },
  { href: "/app/admin/negocios", label: "Negocios", icon: Store },
  { href: "/app/admin/eventos", label: "Eventos", icon: CalendarDays },
  { href: "/app/admin/reclamos", label: "Reclamos", icon: UserCheck },
  { href: "/app/admin/avisos", label: "Avisos", icon: Megaphone },
  { href: "/app/admin/telefonos", label: "Teléfonos", icon: Phone },
  { href: "/app/admin/farmacias", label: "Turnos farmacia", icon: Pill },
  { href: "/app/admin/categorias", label: "Categorías", icon: Tags },
  { href: "/app/admin/mensajes", label: "Mensajes", icon: Mail },
];

const isActive = (item: (typeof NAV)[number]) =>
  item.exact ? path === item.href : path.startsWith(item.href);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} · Admin {adminBarrio.name}</title>
    <ClientRouter />
  </head>

  <body class="bg-gray-100">
    <NavLoader />

    <!-- h-screen + overflow-hidden: el body nunca scrollea; scrollea el
         panel de contenido (sidebar siempre visible) o cada lista interna -->
    <div class="flex h-screen overflow-hidden">
      <!-- Sidebar -->
      <aside
        class="hidden w-56 shrink-0 flex-col border-r border-gray-200 bg-white md:flex"
      >
        <div class="border-b border-gray-100 px-5 py-4">
          {
            barrios.length > 1 ? (
              <select
                id="barrio-select"
                class="w-full rounded-lg border border-gray-200 bg-white px-2 py-1.5 text-sm font-bold"
                aria-label="Barrio"
              >
                {barrios.map((b) => (
                  <option value={b.slug} selected={b.id === adminBarrio.id}>
                    {b.name}
                  </option>
                ))}
              </select>
            ) : (
              <p class="font-bold">{adminBarrio.name}</p>
            )
          }
          <p class="mt-1 text-xs text-gray-400">Panel de control</p>
        </div>

        <nav class="flex flex-1 flex-col gap-1 overflow-y-auto p-3">
          {
            NAV.map((item) => (
              <a
                href={item.href}
                class={`flex items-center gap-3 rounded-xl px-4 py-2.5 text-sm font-medium transition ${
                  isActive(item)
                    ? "bg-primary text-white"
                    : "text-gray-600 hover:bg-gray-100"
                }`}
              >
                <item.icon size={18} />
                {item.label}
              </a>
            ))
          }
        </nav>

        <div class="space-y-2 border-t border-gray-100 p-3">
          <a
            href="/"
            class="flex items-center gap-3 rounded-xl px-4 py-2 text-sm text-gray-500 hover:bg-gray-100"
          >
            <Globe size={18} /> Ver el sitio
          </a>
          <form method="POST" action="/api/auth/signout">
            <button
              type="submit"
              class="flex w-full items-center gap-3 rounded-xl px-4 py-2 text-left text-sm text-gray-500 hover:bg-gray-100"
            >
              <LogOut size={18} /> Salir
            </button>
          </form>
        </div>
      </aside>

      <!-- Contenido -->
      <div class="flex min-w-0 flex-1 flex-col">
        <!-- Barra superior mobile -->
        <div
          class="flex shrink-0 items-center gap-2 overflow-x-auto border-b border-gray-200 bg-white px-4 py-3 md:hidden"
        >
          {
            NAV.map((item) => (
              <a
                href={item.href}
                class={`whitespace-nowrap rounded-full px-3 py-1.5 text-xs font-semibold ${
                  isActive(item)
                    ? "bg-primary text-white"
                    : "bg-gray-100 text-gray-600"
                }`}
              >
                {item.label}
              </a>
            ))
          }
        </div>

        <main class="min-h-0 flex-1 overflow-y-auto p-5 md:p-8">
          <slot />
        </main>
      </div>
    </div>

    <script define:vars={{ cookieName: ADMIN_BARRIO_COOKIE }} is:inline>
      // Cambio de barrio: cookie + recarga completa (el server re-renderiza
      // todo el panel con los datos del barrio elegido)
      document.addEventListener("change", (e) => {
        const select = e.target;
        if (!(select instanceof HTMLSelectElement)) return;
        if (select.id !== "barrio-select") return;
        document.cookie = `${cookieName}=${select.value}; path=/; max-age=31536000; samesite=lax`;
        window.location.reload();
      });
    </script>
  </body>
</html>
