---
import Header from "../components/header/Header.astro";
import Footer from "../components/footer/Footer.astro";
import { ClientRouter } from "astro:transitions";

import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  /** URL absoluta de imagen para compartir en redes (og:image). */
  image?: string;
}

const {
  title = "El Talar — Guía del barrio",
  description = "Guía de El Talar, Tigre: negocios y servicios del barrio, farmacias de turno y teléfonos útiles, todo en un solo lugar.",
  image,
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph (WhatsApp, Facebook, etc.) -->
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="El Talar" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    {image && <meta property="og:image" content={image} />}

    <meta
      name="twitter:card"
      content={image ? "summary_large_image" : "summary"}
    />

    <ClientRouter />
  </head>

  <body class="bg-gray-100">
    <!-- Barra de progreso de navegación (feedback de que algo está cargando) -->
    <div
      id="nav-loader"
      class="pointer-events-none fixed inset-x-0 top-0 z-[100] h-[3px]"
    >
      <div id="nav-loader-bar" class="h-full w-0 bg-primary opacity-0"></div>
    </div>

    <script>
      const bar = document.getElementById("nav-loader-bar")!;
      let hideTimer: ReturnType<typeof setTimeout> | undefined;

      const start = () => {
        clearTimeout(hideTimer);
        // arranca visible y "gotea" hasta 85% mientras espera al servidor
        bar.style.transition = "none";
        bar.style.opacity = "1";
        bar.style.width = "0%";
        requestAnimationFrame(() => {
          bar.style.transition =
            "width 5s cubic-bezier(0.08, 0.82, 0.17, 1), opacity 0.3s ease";
          bar.style.width = "85%";
        });
      };

      const done = () => {
        bar.style.transition = "width 0.2s ease, opacity 0.3s ease 0.25s";
        bar.style.width = "100%";
        bar.style.opacity = "0";
        hideTimer = setTimeout(() => {
          bar.style.transition = "none";
          bar.style.width = "0%";
        }, 600);
      };

      // Eventos del ClientRouter de Astro: cubren toda navegación interna
      document.addEventListener("astro:before-preparation", start);
      document.addEventListener("astro:page-load", done);
    </script>

    <Header />
    <main class="flex flex-col gap-20 sm:mx-20 sm:my-10 mx-4 my-5">
      <slot />
    </main>
    <Footer />
  </body>
</html>
